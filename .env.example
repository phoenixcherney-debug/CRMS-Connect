# Supabase Configuration
# Get these from your Supabase project: Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Push Notifications (VAPID)
# Generate keys with: npx web-push generate-vapid-keys
# Then add VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, VAPID_SUBJECT to your
# Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets)
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# ─── SETUP CHECKLIST ───────────────────────────────────────────────────────────
#
# 1. Create a new Supabase project at https://supabase.com
#
# 2. Run the migration SQL from supabase/migrations/001_initial_schema.sql
#    in the Supabase SQL Editor (Database → SQL Editor)
#
# 3. Copy your Project URL and anon key into .env (copy this file to .env)
#
# 4. Deploy the Edge Function:
#    a. Install Supabase CLI: brew install supabase/tap/supabase
#    b. supabase login
#    c. supabase link --project-ref <your-project-ref>
#    d. supabase functions deploy validate-signup
#
# 5. (Optional) Configure the Edge Function as an Auth Webhook:
#    Supabase Dashboard → Authentication → Hooks
#    Add a webhook for "signup" pointing to your deployed function URL
#
# 6. Enable Email Auth in Supabase:
#    Authentication → Providers → Email → Enable
#
# 7. Set your Site URL for email redirects:
#    Authentication → URL Configuration → Site URL
#    Development: http://localhost:5173
#    Production: https://your-domain.com
#
# ───────────────────────────────────────────────────────────────────────────────
